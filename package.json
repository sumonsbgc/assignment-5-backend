{
	"name": "movie-portal-backend",
	"version": "1.0.0",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"worker": "tsx watch src/workers/video-worker.ts",
		"worker:prod": "node dist/workers/video-worker.js",
		"build": "tsup src/index.ts src/workers/video-worker.ts --format esm --dts --out-dir dist",
		"start": "node dist/index.js",
		"db:migrate": "prisma migrate dev",
		"db:generate": "prisma generate",
		"db:seed": "tsx prisma/seed.ts",
		"db:studio": "prisma studio",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.820.0",
		"@aws-sdk/s3-request-presigner": "^3.820.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"argon2": "^0.43.0",
		"bullmq": "^5.34.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"dotenv": "^17.4.0",
		"express": "^5.1.0",
		"express-rate-limit": "^7.5.0",
		"ffmpeg-static": "^5.2.0",
		"ffprobe-static": "^3.1.0",
		"fluent-ffmpeg": "^2.1.3",
		"helmet": "^8.1.0",
		"ioredis": "^5.6.1",
		"jsonwebtoken": "^9.0.2",
		"pino": "^9.6.0",
		"pino-http": "^10.4.0",
		"rate-limit-redis": "^4.2.0",
		"stripe": "^17.7.0",
		"uuid": "^11.1.0",
		"zod": "^3.25.28"
	},
	"devDependencies": {
		"@types/cookie-parser": "^1.4.9",
		"@types/cors": "^2.8.18",
		"@types/express": "^5.0.3",
		"@types/fluent-ffmpeg": "^2.1.27",
		"@types/jsonwebtoken": "^9.0.9",
		"@types/node": "^22.15.3",
		"@types/uuid": "^10.0.0",
		"pino-pretty": "^13.1.3",
		"prisma": "^7.8.0",
		"tsup": "^8.4.0",
		"tsx": "^4.19.3",
		"typescript": "^5.8.3"
	}
}
